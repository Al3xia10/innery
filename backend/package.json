{
  "name": "innery-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "db:migrate": "sequelize-cli db:migrate --config config/config.js --migrations-path migrations",
    "db:migrate:undo": "sequelize-cli db:migrate:undo --config config/config.js --migrations-path migrations",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all --config config/config.js --migrations-path migrations",
    "db:migrate:status": "sequelize-cli db:migrate:status --config config/config.js --migrations-path migrations",
    "db:seed:all": "sequelize-cli db:seed:all --config config/config.js --seeders-path seeders",
    "db:seed:undo:all": "sequelize-cli db:seed:undo:all --config config/config.js --seeders-path seeders",
    "migration:generate": "sequelize-cli migration:generate --config config/config.js --migrations-path migrations",
    "seed:generate": "sequelize-cli seed:generate --config config/config.js --seeders-path seeders"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.16.3",
    "nodemailer": "^6.9.15",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
